{
  "name": "stockflow-api",
  "version": "1.0.0",
  "description": "API RESTful para gestión de inventario y pedidos",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "npx prisma migrate dev --url file:./prisma/dev.db",
    "prisma:seed": "ts-node src/db/seed.ts",
    "prisma:studio": "npx prisma studio --url file:./prisma/dev.db",
    "prisma:reset": "node -e \"const fs=require('fs'); const db='./prisma/dev.db', jr='./prisma/dev.db-journal'; if(fs.existsSync(db)) fs.unlinkSync(db); if(fs.existsSync(jr)) fs.unlinkSync(jr);\" && npm run prisma:migrate && npm run prisma:seed"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^5.2.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.1.0",
    "prisma": "^7.7.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2"
  }
}